{
  "info": {
    "name": "E-Commerce Microservice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "cartSessionId",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "inventoryId",
      "value": ""
    },
    {
      "key": "orderId",
      "value": ""
    },
    {
      "key": "keycloakUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "realm",
      "value": "ecommerce"
    },
    {
      "key": "clientId",
      "value": "ecommerce-api"
    },
    {
      "key": "adminUsername",
      "value": "admin@example.com"
    },
    {
      "key": "adminPassword",
      "value": "Admin123!"
    },
    {
      "key": "customerUsername",
      "value": "customer@example.com"
    },
    {
      "key": "customerPassword",
      "value": "Customer123!"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Auth Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/health"
          }
        },
        {
          "name": "Product Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/health"
          }
        },
        {
          "name": "Cart Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/cart/health"
          }
        },
        {
          "name": "Order Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Keycloak Admin Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set(\"accessToken\", json.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{clientId}}",
                  "type": "text"
                },
                {
                  "key": "username",
                  "value": "{{adminUsername}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{adminPassword}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": [
                "{{keycloakUrl}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Keycloak Customer Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set(\"accessToken\", json.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{clientId}}",
                  "type": "text"
                },
                {
                  "key": "username",
                  "value": "{{customerUsername}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{customerPassword}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": [
                "{{keycloakUrl}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Portfolio User\",\n  \"email\": \"portfolio@example.com\",\n  \"password\": \"Pass1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"portfolio@example.com\",\n  \"code\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-email"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.accessToken) pm.collectionVariables.set('accessToken', body.accessToken);",
                  "if (body.refreshToken) pm.collectionVariables.set('refreshToken', body.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"portfolio@example.com\",\n  \"password\": \"Pass1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products?page=1&limit=20"
          }
        },
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) pm.collectionVariables.set('productId', body.id);",
                  "if (body.inventoryId) pm.collectionVariables.set('inventoryId', body.inventoryId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"PORTFOLIO-SKU-001\",\n  \"name\": \"Portfolio Demo Product\",\n  \"description\": \"Created from the Postman portfolio collection\",\n  \"price\": 29.99,\n  \"status\": \"PUBLISHED\"\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Get Product Details",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Cart And Checkout",
      "item": [
        {
          "name": "Add To Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const sessionId = pm.response.headers.get('x-cart-session-id');",
                  "if (sessionId) pm.collectionVariables.set('cartSessionId', sessionId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Cart-Session-Id",
                "value": "{{cartSessionId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"inventoryId\": \"{{inventoryId}}\",\n  \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/cart/add-to-cart"
          }
        },
        {
          "name": "Get My Cart",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Cart-Session-Id",
                "value": "{{cartSessionId}}"
              }
            ],
            "url": "{{baseUrl}}/cart/me"
          }
        },
        {
          "name": "Checkout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) pm.collectionVariables.set('orderId', body.id);",
                  "if (body.order && body.order.id) pm.collectionVariables.set('orderId', body.order.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartSessionId\": \"{{cartSessionId}}\"\n}"
            },
            "url": "{{baseUrl}}/orders/checkout"
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        }
      ]
    }
  ]
}
