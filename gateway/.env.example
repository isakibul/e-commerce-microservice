PORT=8081

# Must match every service.
INTERNAL_GATEWAY_SECRET=replace-with-a-long-random-secret

# Outbound proxy timeout in milliseconds.
REQUEST_TIMEOUT_MS=5000

# Local service URLs. Use Docker service names when running inside Docker Compose.
PRODUCT_SERVICE_URL=http://localhost:4001
INVENTORY_SERVICE_URL=http://localhost:4002
AUTH_SERVICE_URL=http://localhost:4003
USER_SERVICE_URL=http://localhost:4004
EMAIL_SERVICE_URL=http://localhost:4005
CART_SERVICE_URL=http://localhost:4006
ORDER_SERVICE_URL=http://localhost:4007

