# Shared local development values.
# Copy the relevant service-specific .env.example into each service folder.

NODE_ENV=development

# Must be identical in Kong and every service.
INTERNAL_GATEWAY_SECRET=replace-with-a-long-random-secret

# Required by auth service. Do not use the fallback/dev placeholder.
JWT_SECRET=replace-with-a-long-random-jwt-secret

# Keycloak local identity provider.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
KEYCLOAK_ISSUER=http://localhost:8080/realms/ecommerce
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/ecommerce/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=ecommerce-api
KEYCLOAK_CLIENT_ID=ecommerce-api

# Local infrastructure from docker-compose.yaml
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
REDIS_HOST=localhost
REDIS_PORT=6380
SMTP_HOST=localhost
SMTP_PORT=1025
QUEUE_URL=amqp://guest:guest@localhost:5672
EMAIL_EXCHANGE=email.events
ORDER_EXCHANGE=order.events
ORDER_RETRY_EXCHANGE=order.events.retry
ORDER_DLX=order.events.dlx
QUEUE_RETRY_DELAY_MS=5000
QUEUE_MAX_RETRIES=3

# Kong local endpoints from docker-compose.yaml
KONG_PROXY_URL=http://localhost:8000
KONG_ADMIN_URL=http://127.0.0.1:8001
KONG_MANAGER_URL=http://127.0.0.1:8002
KEYCLOAK_URL=http://localhost:8080
