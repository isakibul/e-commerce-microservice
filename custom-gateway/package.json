{
  "name": "legacy-express-gateway",
  "version": "1.0.0",
  "description": "Archived Express gateway kept only as migration/reference material. Kong is the active gateway.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Legacy Express gateway is archived; no active test suite.\"",
    "dev": "ts-node-dev --respawn -r tsconfig-paths/register src/index.ts",
    "build": "tsc && tsc-alias",
    "migrate:dev": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy"
  },
  "keywords": [
    "legacy",
    "gateway",
    "reference"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.4.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
